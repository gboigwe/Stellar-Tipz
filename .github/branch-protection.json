{
  "_comment": "Documents the intended branch protection settings for the main branch. Apply via GitHub Settings → Branches or the GitHub API (PATCH /repos/{owner}/{repo}/branches/main/protection).",
  "branch": "main",
  "required_status_checks": {
    "strict": true,
    "contexts": [
      "frontend-ci",
      "contract-ci",
      "pr-checks",
      "security-audit"
    ]
  },
  "enforce_admins": true,
  "required_pull_request_reviews": {
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": false
  },
  "restrictions": null,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "required_linear_history": true,
  "required_conversation_resolution": true,
  "require_signed_commits": true
}
